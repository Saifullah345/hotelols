NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public URL of the deployed app. Used to build auth email links (signup
# confirmation + customer invites) so they always point at the live site
# instead of localhost. Defaults to https://hotelols.vercel.app when unset.
# This exact URL must also be added under Supabase → Authentication →
# URL Configuration (Site URL + Redirect URLs).
NEXT_PUBLIC_SITE_URL=https://hotelols.vercel.app
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — transactional email (login OTP + branded emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender. Use onboarding@resend.dev only for testing (delivers solely
# to your own Resend account email); switch to a verified domain for production.
RESEND_FROM=HotelOS <onboarding@resend.dev>
# Require a one-time email code on every customer login ("false" to disable).
CUSTOMER_LOGIN_OTP=true
# Optional: absolute URL to a logo image for branded emails (falls back to a text logo).
EMAIL_LOGO_URL=
# Optional: override the secret used to sign OTP challenge cookies (defaults to the service role key).
OTP_SECRET=
