NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public URL of the deployed app. Used to build auth email links (signup
# confirmation + customer invites) so they always point at the live site
# instead of localhost. Defaults to https://hotelmanagement.n6solution.com.
# This exact URL must also be added under Supabase → Authentication →
# URL Configuration (Site URL + Redirect URLs), or the verify link falls back
# to Supabase's Site URL (often http://localhost:3000).
NEXT_PUBLIC_SITE_URL=https://hotelmanagement.n6solution.com
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — transactional email (login OTP + branded emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender — must be an address on a domain you've verified in Resend.
# onboarding@resend.dev only delivers to your own Resend account email (testing).
RESEND_FROM=HotelOS <noreply@hotelmanagement.n6solution.com>
# Require a one-time email code on every customer login ("false" to disable).
CUSTOMER_LOGIN_OTP=true
# Optional: absolute URL to a logo image for branded emails (falls back to a text logo).
EMAIL_LOGO_URL=
# Optional: override the secret used to sign OTP challenge cookies (defaults to the service role key).
OTP_SECRET=
